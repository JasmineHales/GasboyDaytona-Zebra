# Copy to .env.local (never commit .env.local)

# Required for `npm run dev:lan` (mobile testing on same Wi-Fi). Use a long random string.
# Open on phone: https://<your-mac-ip>:5174/?token=<this-value>
DEV_ACCESS_TOKEN=replace-with-a-long-random-secret

# Set to true on Vercel to enable the dev panel + Zebra EM45 frame on production builds.
# Auto-enabled on *.vercel.app hosts; use ?demo=1 elsewhere.
VITE_ENABLE_DEMO_PANEL=true
